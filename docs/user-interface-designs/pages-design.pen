                          "id": "HqwLh",
                          "fill": "#A6C8FF",
                          "content": "## Facts",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "V8RPi",
                          "fill": "#E6E1E5",
                          "content": "- brain-dump.md is the source-of-truth facts document.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HyXWn",
                          "fill": "#E6E1E5",
                          "content": "- It contains pure facts only — no lifecycle, no status,",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "iqaxH",
                          "fill": "#E6E1E5",
                          "content": "  no links to other documents, and no proposals.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "u7IPr",
                          "fill": "#E6E1E5",
                          "content": "- Authored and reviewed by the owner.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "BOtjS",
