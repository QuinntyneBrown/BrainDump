                          "type": "text",
                          "id": "fDWoK",
                          "fill": "#A6C8FF",
                          "content": "# L1 architecture",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 20,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "w845E0",
                          "width": 1,
                          "height": 6
                        },
                        {
                          "type": "text",
                          "id": "O0jY6y",
                          "fill": "#A6C8FF",
                          "content": "## Components",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "GRb8Q",
                          "fill": "#E6E1E5",
                          "content": "- Single Angular SPA + .NET API + SQL Server.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "wADPR",
                          "fill": "#E6E1E5",
                          "content": "- Sections form a tree; facts attach to sections.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "j1t81",
                          "fill": "#E6E1E5",
                          "content": "- Auth: PKCE (local) + Entra ID (production).",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "rtZG8",
                          "width": 1,
                          "height": 6
                        },
                        {
                          "type": "text",
                          "id": "x0bza",
                          "fill": "#A6C8FF",
                          "content": "## Constraints",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "I1FwLC",
                          "fill": "#E6E1E5",
                          "content": "- p95 < 200ms for /api/tree on 10k facts.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Y9Xfur",
                          "fill": "#E6E1E5",
                          "content": "- Single-editor; no multi-tenant work in scope.",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
