@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Recent Activity - Containers

Person(editor, "Editor")
System_Boundary(bd, "BrainDump") {
    Container(spa, "SPA", "Angular", "Shows recents list")
    Container(api, "API", ".NET 9", "POST view, GET recents")
    ContainerDb(db, "SQL Server", "Azure SQL", "user_document_view")
}

Rel(editor, spa, "Uses", "HTTPS")
Rel(spa, api, "/api/documents/{id}/view, /api/recent", "JSON")
Rel(api, db, "Upsert / select recents", "T-SQL")

@enduml
