@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Multi-Document Editing - Containers

Person(editor, "Editor")

System_Boundary(bd, "BrainDump") {
    Container(spa, "SPA", "Angular", "Tab bar, split editor")
    Container(api, "API", ".NET 9", "/api/tabs read/write")
    ContainerDb(db, "SQL Server", "Azure SQL", "user_tab_state row per user")
}

Rel(editor, spa, "Uses", "HTTPS")
Rel(spa, api, "GET/PUT /api/tabs", "JSON")
Rel(api, db, "Read/Write JSON column", "T-SQL")

@enduml
