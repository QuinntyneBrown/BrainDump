@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Page Templates - Containers

Person(editor, "Editor")
System_Boundary(bd, "BrainDump") {
    Container(spa, "SPA", "Angular", "Templates dialog + page tree entry point")
    Container(api, "API", ".NET 9", "Templates CRUD + instantiation")
    ContainerDb(db, "SQL Server", "Azure SQL", "template, template_section, template_fact")
}

Rel(editor, spa, "Uses", "HTTPS")
Rel(spa, api, "/api/templates, /api/documents { templateId }", "JSON")
Rel(api, db, "Read templates / deep-copy into document", "T-SQL")

@enduml
