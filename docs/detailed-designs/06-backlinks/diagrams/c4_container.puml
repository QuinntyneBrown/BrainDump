@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Backlinks - Containers

Person(editor, "Editor")
System_Boundary(bd, "BrainDump") {
    Container(spa, "SPA", "Angular", "Right rail backlinks panel")
    Container(api, "API", ".NET 9", "Mutation handlers refresh links inline")
    ContainerDb(db, "SQL Server", "Azure SQL", "document_link")
}

Rel(editor, spa, "Uses", "HTTPS")
Rel(spa, api, "GET /api/documents/{id}/backlinks", "JSON")
Rel(api, db, "Refresh + read links", "T-SQL")

@enduml
