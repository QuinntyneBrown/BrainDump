@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Documents and Folders - Containers

Person(editor, "Editor")

System_Boundary(bd, "BrainDump") {
    Container(spa, "SPA", "Angular", "Page tree, editor, workspace navigation")
    Container(api, "API", ".NET 9 / MediatR", "Folders, documents, sections, facts CRUD")
    ContainerDb(db, "SQL Server", "Azure SQL / mssql container", "folder, document, section, fact tables")
}

Rel(editor, spa, "Uses", "HTTPS")
Rel(spa, api, "/api/workspace, /api/folders, /api/documents, /api/move", "JSON/HTTPS")
Rel(api, db, "Reads/Writes", "T-SQL")

@enduml
