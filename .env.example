# Copy to `.env` on first checkout. Compose reads it automatically.
#
# SA password for the local SQL Server container. Must satisfy MSSQL's
# default password policy (>= 8 chars; mix of upper/lower/digit/symbol).
# This credential is local-development-only — see L1-013 / L2-030.
MSSQL_SA_PASSWORD=Your_strong!Passw0rd
