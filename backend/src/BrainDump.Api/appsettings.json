{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=<azure-sql-server>.database.windows.net;Database=BrainDump;Authentication=Active Directory Default;"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Database": {
    "EnsureCreatedOnStartup": true
  },
  "Jwt": {
    "UseLocalAuth": false,
    "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
    "Audience": "<client-id>"
  }
}
