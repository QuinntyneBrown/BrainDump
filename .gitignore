# Local Claude Code runtime state (lock files, scheduled task data, etc.)
.claude/

# Dev-server log files written by background process launchers.
# Always write logs into the top-level logs/ directory — kept by .gitkeep,
# contents ignored.
logs/*
!logs/.gitkeep
*.log
*-out.txt
*-err.txt

# Local SQLite database files (Development uses Sqlite via Database:Provider).
*.db
*.db-shm
*.db-wal

# Local Compose environment overrides — committed template lives in .env.example.
.env

# Host-specific Compose overrides (e.g. ARM64 hosts that swap SQL Server for
# Azure SQL Edge). Auto-loaded by `docker compose up`; not committed.
docker-compose.override.yml
docker-compose.override.yaml

# Ad-hoc screenshots and recordings captured during development
*.png
*.webm
