# Local Claude Code runtime state (lock files, scheduled task data, etc.)
.claude/

# Dev-server log files written by background process launchers.
# Always write logs into the top-level logs/ directory — kept by .gitkeep,
# contents ignored.
logs/*
!logs/.gitkeep
*.log
*-out.txt
*-err.txt

# Local SQLite database files (Development uses Sqlite via Database:Provider).
*.db
*.db-shm
*.db-wal

# Ad-hoc screenshots and recordings captured during development
*.png
*.webm
